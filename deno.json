{
  "nodeModulesDir": "manual",
  "tasks": {
    "stop": "pm2 stop josefabio",
    "logs": "pm2 logs josefabio",
    "delete": "pm2 delete josefabio",
    "reload": "deno task build && pm2 reload josefabio && pm2 logs josefabio",
    "start": "deno task build && DENO_DEPLOYMENT_ID=\"$(git rev-parse HEAD)\" pm2 start --interpreter='deno' --interpreter-args='serve --port=5055 -A' --name josefabio _fresh/server.js && pm2 logs josefabio",
    "check": "deno check --allow-import main.ts",
    "preview": "deno serve --port=5056 -A _fresh/server.js",
    "update_deps": "deno outdated",
    "update_deps_now": "deno outdated --update --latest",
    "dev": "vite --port=5056",
    "build": "vite build",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "fresh": "jsr:@fresh/core@^2.3.0",
    "preact": "npm:preact@^10.27.2",
    "prettier-plugin-tailwindcss": "npm:prettier-plugin-tailwindcss@^0.6.11",
    "prettier": "npm:prettier@^3.5.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "vite": "npm:vite@^7.1.3"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
