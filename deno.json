{
  "nodeModulesDir": "manual",
  "tasks": {
    "stop": "pm2 stop josefabio",
    "logs": "pm2 logs josefabio",
    "delete": "pm2 delete josefabio",
    "reload": "deno task build && pm2 reload josefabio && pm2 logs josefabio",
    "start": "deno task build && DENO_DEPLOYMENT_ID=\"$(git rev-parse HEAD)\" pm2 start --interpreter='deno' --interpreter-args='serve --port=5055 -A' --name josefabio _fresh/server.js && pm2 logs josefabio",
    "check": "deno check --allow-import main.ts",
    "preview": "deno serve --port=5056 -A _fresh/server.js",
    "update_deps": "deno outdated",
    "update_deps_now": "deno outdated --update --latest",
    "dev": "vite --port=5056",
    "build": "vite build",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "fresh": "jsr:@fresh/core@^2.3.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "@preact-icons/ai": "jsr:@preact-icons/ai@^1.0.13",
    "@preact-icons/bi": "jsr:@preact-icons/bi@^1.0.13",
    "@preact-icons/bs": "jsr:@preact-icons/bs@^1.0.13",
    "@preact-icons/cg": "jsr:@preact-icons/cg@^1.0.13",
    "@preact-icons/ci": "jsr:@preact-icons/ci@^1.0.13",
    "@preact-icons/di": "jsr:@preact-icons/di@^1.0.13",
    "@preact-icons/fa": "jsr:@preact-icons/fa@^1.0.13",
    "@preact-icons/fc": "jsr:@preact-icons/fc@^1.0.13",
    "@preact-icons/fi": "jsr:@preact-icons/fi@^1.0.13",
    "@preact-icons/gi": "jsr:@preact-icons/gi@^1.0.13",
    "@preact-icons/go": "jsr:@preact-icons/go@^1.0.13",
    "@preact-icons/gr": "jsr:@preact-icons/gr@^1.0.13",
    "@preact-icons/hi": "jsr:@preact-icons/hi@^1.0.13",
    "@preact-icons/hi2": "jsr:@preact-icons/hi2@^1.0.13",
    "@preact-icons/im": "jsr:@preact-icons/im@^1.0.13",
    "@preact-icons/io": "jsr:@preact-icons/io@^1.0.13",
    "@preact-icons/io5": "jsr:@preact-icons/io5@^1.0.13",
    "@preact-icons/lu": "jsr:@preact-icons/lu@^1.0.13",
    "@preact-icons/md": "jsr:@preact-icons/md@^1.0.13",
    "@preact-icons/ri": "jsr:@preact-icons/ri@^1.0.13",
    "@preact-icons/rx": "jsr:@preact-icons/rx@^1.0.13",
    "@preact-icons/si": "jsr:@preact-icons/si@^1.0.13",
    "@preact-icons/sl": "jsr:@preact-icons/sl@^1.0.13",
    "@preact-icons/tb": "jsr:@preact-icons/tb@^1.0.13",
    "@preact-icons/tfi": "jsr:@preact-icons/tfi@^1.0.13",
    "@preact-icons/ti": "jsr:@preact-icons/ti@^1.0.13",
    "@preact-icons/vsc": "jsr:@preact-icons/vsc@^1.0.13",
    "@preact-icons/wi": "jsr:@preact-icons/wi@^1.0.13",
    "@safe-env/safe-env": "jsr:@safe-env/safe-env@^0.1.7",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.3",
    "prettier": "npm:prettier@^3.5.3",
    "prettier-plugin-tailwindcss": "npm:prettier-plugin-tailwindcss@^0.6.11",
    "react-icons": "npm:react-icons@^5.5.0",
    "@std/path": "jsr:@std/path@^1.0.8"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
